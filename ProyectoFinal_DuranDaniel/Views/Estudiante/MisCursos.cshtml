@model IEnumerable<ProyectoFinal_DuranDaniel.Models.Matricula>
@{
    ViewData["Title"] = "Mis Cursos";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Mis Cursos Matriculados</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            padding: 2rem;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            max-width: 650px;
            margin: auto;
        }

        h2 {
            color: #333;
            margin-bottom: 1.5rem;
        }

        .empty {
            color: #666;
            text-align: center;
            padding: 2rem;
        }

        .item {
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            padding: 1rem;
            margin-bottom: .8rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nombre {
            font-weight: bold;
        }

        .meta {
            font-size: .85rem;
            color: #666;
            margin-top: .2rem;
        }

        .badge {
            padding: .35rem .9rem;
            background: #e8f5e9;
            color: #2e7d32;
            border-radius: 12px;
            font-size: .8rem;
            font-weight: bold;
        }

        a.back {
            display: inline-block;
            margin-top: 1rem;
            color: #1a73e8;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>Mis Cursos Matriculados</h2>

        @if (!Model.Any())
        {
            <div class="empty">No tenés cursos matriculados aún.</div>
        }
        else
        {
            @foreach (var m in Model)
            {
                <div class="item">
                    <div>
                        <div class="nombre">@m.Curso.Nombre</div>
                        <div class="meta">
                            Carrera: @m.Curso.Carrera.Nombre &nbsp;|&nbsp;
                            Docente: @m.Curso.Docente.Nombre @m.Curso.Docente.Apellido
                        </div>
                        <div class="meta">
                            Matriculado el: @m.FechaMatricula.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                    <span class="badge">@m.Estado</span>
                </div>
            }
        }

        <a class="back" href="/Estudiante/Carreras">← Volver a carreras</a>
    </div>
</body>
</html>