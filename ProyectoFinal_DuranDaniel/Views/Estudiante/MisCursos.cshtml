@model IEnumerable<ProyectoFinal_DuranDaniel.Models.Matricula>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mis Cursos";
}

<div class="container mt-4">
    <h3 class="fw-bold mb-4">🎓 Mis Cursos Matriculados</h3>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Aún no estás matriculado en ningún curso.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var m in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="fw-bold">@m.Curso?.Nombre</h5>
                        <p class="text-muted small">@m.Curso?.Carrera?.Nombre</p>
                        <p class="small">Docente: @m.Curso?.Docente?.Nombre @m.Curso?.Docente?.Apellido</p>
                        <span class="badge bg-success">@m.Estado</span>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Curso" asp-controller="Material"
                           asp-route-cursoId="@m.CursoId"
                           class="btn btn-sm btn-primary">
                            ☁️ Ver materiales
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
