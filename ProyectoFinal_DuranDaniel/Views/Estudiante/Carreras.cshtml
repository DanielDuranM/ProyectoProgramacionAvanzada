@model IEnumerable<ProyectoFinal_DuranDaniel.Models.Carrera>
@{
    ViewData["Title"] = "Carreras Disponibles";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Carreras Disponibles</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f0f2f5; padding: 2rem; }
        .card { background: white; padding: 2rem; border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,.1); max-width: 600px; margin: auto; }
        h2 { color: #333; margin-bottom: 1.5rem; }
        .item { border: 1px solid #e0e0e0; border-radius: 6px; padding: 1rem;
                margin-bottom: .8rem; display: flex;
                justify-content: space-between; align-items: center; }
        .nombre { font-weight: bold; font-size: 1.05rem; }
        .desc { font-size: .85rem; color: #666; margin-top: .2rem; }
        a.btn { padding: .5rem 1.2rem; background: #1a73e8; color: white;
                text-decoration: none; border-radius: 4px; font-size: .9rem; }
        a.btn:hover { background: #1558b0; }
        a.back { display: inline-block; margin-top: 1rem;
                 color: #1a73e8; text-decoration: none; }
    </style>
</head>
<body>
<div class="card">
    <h2>Carreras Disponibles</h2>

    @foreach (var c in Model)
    {
        <div class="item">
            <div>
                <div class="nombre">@c.Nombre</div>
                <div class="desc">@c.Descripcion</div>
            </div>
            <a class="btn" href="/Estudiante/Cursos?carreraId=@c.Id">Ver Cursos</a>
        </div>
    }

    <a class="back" href="/Home/Index">← Volver al inicio</a>
</div>
</body>
</html>