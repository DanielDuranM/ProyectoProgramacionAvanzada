@model IEnumerable<ProyectoFinal_DuranDaniel.Models.Curso>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mis Cursos";
}

<div class="container mt-4">
    <h3 class="fw-bold mb-4">📖 Mis Cursos</h3>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No tenés cursos asignados actualmente.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var curso in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0" style="border-left:4px solid #1a73e8 !important;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@curso.Nombre</h5>
                        <p class="card-text text-muted small">@curso.Carrera?.Nombre</p>
                        <p class="card-text small">@curso.Descripcion</p>
                        <div class="d-flex gap-2 mt-2">
                            <span class="badge bg-secondary">
                                👥 @curso.Matriculas.Count estudiantes
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="DetalleCurso" asp-controller="Docente"
                           asp-route-id="@curso.Id"
                           class="btn btn-sm btn-outline-primary">
                            👁️ Ver estudiantes
                        </a>
                        <a asp-action="Curso" asp-controller="Material"
                           asp-route-cursoId="@curso.Id"
                           class="btn btn-sm btn-primary">
                            ☁️ Materiales
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
