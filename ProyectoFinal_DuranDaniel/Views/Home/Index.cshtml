@{
    ViewData["Title"] = "Inicio";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Inicio</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            width: 400px;
        }

        h2 {
            color: #333;
        }

        p {
            color: #666;
        }

        .badge {
            display: inline-block;
            background: #1a73e8;
            color: white;
            padding: .3rem .9rem;
            border-radius: 12px;
            font-size: .85rem;
        }

        .menu {
            margin-top: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: .8rem;
        }

        a.btn {
            display: block;
            padding: .7rem;
            background: #1a73e8;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            text-align: center;
        }

            a.btn:hover {
                background: #1558b0;
            }

        a.logout {
            background: #e53935;
        }

            a.logout:hover {
                background: #b71c1c;
            }
    </style>
</head>
<body>
    <div class="card">
        <h2>Bienvenido, @ViewBag.Nombre</h2>
        <p>@ViewBag.Correo</p>
        <span class="badge">@ViewBag.Rol</span>

        <div class="menu">
            @if (ViewBag.Rol == "Administrador")
            {
                <a class="btn" href="/Admin/Index">Panel de Administración</a>
            }
            else if (ViewBag.Rol == "Docente")
            {
                <a class="btn" href="/Docente/MisCursos">Mis Cursos Asignados</a>
            }
            else
            {
                <a class="btn" href="/Estudiante/Carreras">Seleccionar Carrera y Matricularme</a>
                <a class="btn" href="/Estudiante/MisCursos">Mis Cursos Matriculados</a>
            }
            <a class="btn logout" href="/Auth/Logout">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>