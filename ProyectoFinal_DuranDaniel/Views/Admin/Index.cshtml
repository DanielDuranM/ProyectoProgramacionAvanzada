@{
    ViewData["Title"] = "Administración";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Menú Administración</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            padding: 2rem;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            max-width: 500px;
            margin: auto;
        }

        h2 {
            color: #333;
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        a.btn {
            display: block;
            padding: 1rem;
            background: #1a73e8;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            text-align: center;
            font-weight: bold;
        }

            a.btn:hover {
                background: #1558b0;
            }

        a.back {
            display: inline-block;
            margin-top: 1rem;
            color: #1a73e8;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>Menú Administración</h2>
        <div class="grid">
            <a class="btn" href="/Admin/Docentes">Docentes</a>
            <a class="btn" href="/Admin/Estudiantes">Estudiantes</a>
            <a class="btn" href="/Admin/Carreras">Carreras</a>
            <a class="btn" href="/Admin/Cursos">Cursos</a>
            <a class="btn" href="/Admin/Roles">Roles</a>
        </div>
        <a class="back" href="/Home/Index">← Atrás</a>
    </div>
</body>
</html>