@model IEnumerable<ProyectoFinal_DuranDaniel.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de Docentes";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Gestión de Docentes</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            padding: 2rem;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
        }

        h2 {
            color: #333;
        }

        .msg-ok {
            color: green;
            margin-bottom: 1rem;
        }

        .msg-err {
            color: red;
            margin-bottom: 1rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th {
            background: #1a73e8;
            color: white;
            padding: .7rem 1rem;
            text-align: left;
        }

        td {
            padding: .6rem 1rem;
            border-bottom: 1px solid #eee;
        }

        .btn-del {
            padding: .3rem .8rem;
            background: #e53935;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: .85rem;
        }

            .btn-del:hover {
                background: #b71c1c;
            }

        h3 {
            margin-top: 2rem;
            color: #333;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .6rem;
            margin-top: .8rem;
        }

            .form-grid input {
                padding: .55rem;
                border: 1px solid #ccc;
                border-radius: 4px;
                font-size: .9rem;
            }

            .form-grid button {
                grid-column: span 2;
                padding: .6rem;
                background: #34a853;
                color: white;
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-size: 1rem;
            }

                .form-grid button:hover {
                    background: #2e7d32;
                }

        a.back {
            display: inline-block;
            margin-top: 1rem;
            color: #1a73e8;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>Gestión de Docentes</h2>

        @if (TempData["Mensaje"] != null)
        {
            <p class="msg-ok">@TempData["Mensaje"]</p>
        }
        @if (TempData["Error"] != null)
        {
            <p class="msg-err">@TempData["Error"]</p>
        }

        <table>
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td>@d.Id</td>
                        <td>@d.Nombre</td>
                        <td>@d.Apellido</td>
                        <td>@d.CorreoPersonal</td>
                        <td>@d.Telefono</td>
                        <td>
                            <form method="post" action="/Admin/EliminarDocente" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@d.Id" />
                                <button class="btn-del"
                                        onclick="return confirm('¿Eliminar este docente?')">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h3>Agregar Docente</h3>
        <form method="post" action="/Admin/AgregarDocente" class="form-grid">
            @Html.AntiForgeryToken()
            <input name="nombre" placeholder="Nombre" required />
            <input name="apellido" placeholder="Apellido" required />
            <input name="correoPersonal" placeholder="Correo" type="email" required />
            <input name="identificacion" placeholder="Identificación" required />
            <input name="telefono" placeholder="Teléfono" required />
            <input name="contrasena" placeholder="Contraseña" type="password" required />
            <button type="submit">Agregar Docente</button>
        </form>

        <a class="back" href="/Admin/Index">← Volver al panel</a>
    </div>
</body>
</html>