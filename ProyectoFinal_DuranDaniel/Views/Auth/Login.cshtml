@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Login</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.15);
            width: 320px;
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 1.5rem;
        }

        input {
            width: 100%;
            padding: .6rem;
            margin-bottom: .8rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        button {
            width: 100%;
            padding: .7rem;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
        }

            button:hover {
                background: #1558b0;
            }

        .error {
            color: red;
            font-size: .9rem;
            margin-bottom: .8rem;
        }

        .success {
            color: green;
            font-size: .9rem;
            margin-bottom: .8rem;
        }

        .link {
            text-align: center;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>Iniciar Sesión</h2>

        @if (TempData["Mensaje"] != null)
        {
            <p class="success">@TempData["Mensaje"]</p>
        }
        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <form method="post" asp-action="Login" asp-controller="Auth">
            @Html.AntiForgeryToken()
            <input name="correo" placeholder="Correo" type="email" required />
            <input name="contrasena" placeholder="Contraseña" type="password" required />
            <button type="submit">Iniciar</button>
        </form>
        <div class="link"><a href="/Auth/Register">Registrarse</a></div>
    </div>
</body>
</html>