@model IEnumerable<ProyectoFinal_DuranDaniel.Models.MaterialCurso>
@{
    var curso     = ViewBag.Curso as ProyectoFinal_DuranDaniel.Models.Curso;
    bool esDocente = ViewBag.EsDocente == true;
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Materiales – {curso?.Nombre}";
}

<div class="container mt-4">

    <div class="card shadow-sm mb-4 border-0" style="background:linear-gradient(135deg,#1a73e8,#0d47a1);color:#fff;">
        <div class="card-body d-flex align-items-center gap-3">
            <div style="font-size:2.5rem;">📚</div>
            <div>
                <h4 class="mb-0 fw-bold">@curso?.Nombre</h4>
                <small class="opacity-75">@curso?.Carrera?.Nombre &nbsp;|&nbsp; Docente: @curso?.Docente?.Nombre @curso?.Docente?.Apellido</small>
            </div>
            <span class="ms-auto badge fs-6 px-3 py-2"
                  style="background:rgba(255,255,255,.25);border-radius:999px;">
                @Model.Count() materiales
            </span>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✅ @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            ❌ @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (esDocente)
    {
        <div class="card shadow-sm mb-4 border-2" style="border-color:#1a73e8 !important;">
            <div class="card-header fw-semibold" style="background:#e8f0fe;color:#1a73e8;">
                ☁️ Subir material a Firebase Storage
            </div>
            <div class="card-body">
                <form asp-action="Subir" asp-controller="Material"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="cursoId" value="@curso?.Id" />

                    <div id="dropZone"
                         onclick="document.getElementById('archivoInput').click()"
                         style="border:2px dashed #1a73e8;border-radius:12px;padding:40px;
                                text-align:center;cursor:pointer;transition:background .2s;
                                background:#f8faff;">
                        <div style="font-size:2rem;">📂</div>
                        <p class="mb-1 text-muted">Arrastrá un archivo aquí o <strong>hacé clic</strong> para seleccionar</p>
                        <small class="text-muted">PDF, Word, Excel, imagen · Máx 20 MB</small>
                        <input type="file" id="archivoInput" name="archivo"
                               class="d-none" required
                               onchange="mostrarNombreArchivo(this)" />
                    </div>
                    <div id="nombreArchivo" class="mt-2 text-center text-primary fw-semibold"></div>

                    <div id="barraProgreso" class="progress mt-3 d-none" style="height:8px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                             style="width:100%"></div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary px-4"
                                onclick="mostrarProgreso()">
                            ⬆️ Subir a Firebase
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <h5 class="fw-bold mb-3">📄 Materiales disponibles</h5>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem;">🗂️</div>
            <p class="mt-2">No hay materiales subidos aún.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var m in Model)
            {
                var icono = ObtenerIcono(m.TipoArchivo);
                var tamanio = FormatearTamanio(m.TamanioBytes);

                <div class="col">
                    <div class="card h-100 shadow-sm border-0 material-card"
                         style="border-left:4px solid #1a73e8 !important;border-radius:10px;overflow:hidden;">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div style="font-size:2rem;">@icono</div>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate" title="@m.NombreArchivo">@m.NombreArchivo</div>
                                <small class="text-muted">
                                    @tamanio &nbsp;·&nbsp;
                                    @m.FechaSubida.ToString("dd MMM yyyy HH:mm") &nbsp;·&nbsp;
                                    @m.SubidoPor?.Nombre
                                </small>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="@m.UrlFirebase" target="_blank"
                                   class="btn btn-sm btn-outline-primary" title="Descargar">
                                    ⬇️
                                </a>
                                @if (esDocente)
                                {
                                    <form asp-action="Eliminar" asp-controller="Material"
                                          method="post"
                                          onsubmit="return confirm('¿Eliminar este material de Firebase?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@m.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            🗑️
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="MisCursos" asp-controller="Docente"
           class="btn btn-outline-secondary @(esDocente ? "" : "d-none")">
            ← Volver a Mis Cursos
        </a>
        <a asp-action="MisCursos" asp-controller="Estudiante"
           class="btn btn-outline-secondary @(esDocente ? "d-none" : "")">
            ← Volver a Mis Cursos
        </a>
    </div>
</div>

@section Scripts {
<script>
    // Drag & drop visual
    const dropZone = document.getElementById('dropZone');
    if (dropZone) {
        dropZone.addEventListener('dragover', e => {
            e.preventDefault();
            dropZone.style.background = '#dde9ff';
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.style.background = '#f8faff';
        });
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.style.background = '#f8faff';
            const input = document.getElementById('archivoInput');
            input.files = e.dataTransfer.files;
            mostrarNombreArchivo(input);
        });
    }

    function mostrarNombreArchivo(input) {
        if (input.files.length > 0) {
            document.getElementById('nombreArchivo').textContent =
                '📎 ' + input.files[0].name;
        }
    }

    function mostrarProgreso() {
        document.getElementById('barraProgreso').classList.remove('d-none');
    }
</script>
}

@functions {
    string ObtenerIcono(string tipo)
    {
        if (tipo.Contains("pdf"))   return "📕";
        if (tipo.Contains("word") || tipo.Contains("document")) return "📘";
        if (tipo.Contains("excel") || tipo.Contains("sheet"))   return "📗";
        if (tipo.Contains("image")) return "🖼️";
        if (tipo.Contains("zip") || tipo.Contains("rar"))       return "🗜️";
        return "📄";
    }

    string FormatearTamanio(long bytes)
    {
        if (bytes < 1024)             return $"{bytes} B";
        if (bytes < 1024 * 1024)      return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024.0):F1} MB";
    }
}
